# =============================================================================
# Spotwork — .gitignore (Next.js 16 / macOS)
# =============================================================================

# ----- Dependencies ----------------------------------------------------------
node_modules/
jspm_packages/
web_modules/
bower_components/

# ----- Package managers ------------------------------------------------------
.npm/
.pnpm-store/
.yarn-integrity
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp
.pnp.*

# ----- Logs ------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ----- Runtime / pid ---------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# ----- Next.js ---------------------------------------------------------------
.next/
out/
build/
dist/
next-env.d.ts

# ----- Vercel ----------------------------------------------------------------
.vercel/

# ----- Environment variables (절대 커밋 금지) -------------------------------
# .env.example 는 키 이름만 동기화하기 위해 커밋한다
!.env.example

# ----- TypeScript ------------------------------------------------------------
*.tsbuildinfo

# ----- Testing / Coverage ----------------------------------------------------
coverage/
*.lcov
.nyc_output/
lib-cov/

# ----- ESLint / Prettier / Stylelint cache ----------------------------------
.eslintcache
.stylelintcache
.prettiercache

# ----- Build / Bundler caches -----------------------------------------------
.cache/
.parcel-cache/
.turbo/
.swc/
.rollup.cache/

# ----- Sentry / Bundle analyzer ---------------------------------------------
.sentryclirc
.next/analyze/
report.html

# ----- Compiled binary addons -----------------------------------------------
build/Release/

# ----- node-waf configuration -----------------------------------------------
.lock-wscript

# ----- Optional REPL / history files ----------------------------------------
.node_repl_history

# ----- Output of 'npm pack' --------------------------------------------------
*.tgz
*.tar.gz

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# =============================================================================
# Editors / IDE
# =============================================================================
# VS Code — 공유 설정만 커밋, 나머지는 무시
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.vscode-test/

# JetBrains
.idea/

# Vim / Emacs / 기타
*.swp
*.swo
*~
.history/
*.code-workspace

# =============================================================================
# Misc
# =============================================================================
.tmp/
tmp/
temp/

.next/
.vercel
.env*.local
